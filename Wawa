local TeleportService = game:GetService("TeleportService")
local hopTimer = 0 -- Variabel internal pelacak durasi monster kosong

local function ServerHop()
    local success, errorMessage = pcall(function()
        local serverList = {}
        -- Mengambil daftar server aktif dari game API
        local req = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
        
        for _, server in ipairs(req.data) do
            -- Cari server yang masih muat player lain tetapi bukan server saat ini
            if server.id ~= game.JobId and tostring(server.playing) < tostring(server.maxPlayers) then
                table.insert(serverList, server.id)
            end
        end
        
        if #serverList > 0 then
            -- Pilih server acak dari daftar yang valid
            local randomServer = serverList[math.random(1, #serverList)]
            TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer, player)
        else
            -- Jika gagal menemukan server spesifik, gunakan teleportasi standar
            TeleportService:Teleport(game.PlaceId, player)
        end
    end)
    
    if not success then
        print("KIIBOO LOG: Gagal mencari server, mencoba ulang standar teleport. Error: " .. tostring(errorMessage))
        TeleportService:Teleport(game.PlaceId, player)
    end
end

