-- Fungsi untuk mencari koordinat titik spawn monster berdasarkan ID
local function getSpawnPosition(monsterId)
    if not EntitiesPos then return nil end
    for _, posObj in ipairs(EntitiesPos:GetChildren()) do
        -- Mengecek apakah nama objek di EntitiesPos mengandung ID monster yang dicari
        if string.find(posObj.Name, tostring(monsterId)) and (posObj:IsA("BasePart") or posObj:IsA("Model")) then
            return posObj:IsA("BasePart") and posObj.Position or posObj:GetPivot().Position
        end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    if not Settings.AutoFarm then 
        currentTarget = nil
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.PlatformStand = false
        end
        return 
    end
    
    local char = player.Character
    local hrp, hum = char and char:FindFirstChild("HumanoidRootPart"), char and char:FindFirstChild("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then return end

    local function getWeapon()
        local t = char:FindFirstChildOfClass("Tool") or player.Backpack:FindFirstChildOfClass("Tool")
        return t and (t:GetAttribute("ID") or (t:FindFirstChild("ID") and t.ID.Value))
    end

    local function isValidTarget(monster)
        if not monster or not monster.Parent or not monster:IsDescendantOf(workspace) then return false end
        local mHum = monster:FindFirstChildOfClass("Humanoid")
        if mHum and mHum.Health <= 0 then return false end
        local mPart = monster:FindFirstChild("HumanoidRootPart") or monster.PrimaryPart
        if not mPart then return false end
        return true
    end

    --------------------------------------------------
    -- SYSTEM FIX: VALIDASI REAL-TIME INPUT UI
    --------------------------------------------------
    if currentTarget and isValidTarget(currentTarget) then
        local currentID = tostring(currentTarget:GetAttribute("ID") or (currentTarget:FindFirstChild("ID") and currentTarget.ID.Value))
        
        -- JIKA MONSTER YANG SEDANG DISERANG TERNYATA SUDAH DIMATIKAN DI UI (BAIK PRIORITY MAUPUN NORMAL), LANGSUNG LEPAS!
        if not Settings.PriorityIDs[currentID] and not Settings.ActiveIDs[currentID] then
            currentTarget = nil
        else
            -- INTERUPSI MUTLAK: Jika target saat ini adalah Monster Normal, tapi tiba-tiba ada Priority ID yang aktif & spawn, LANGSUNG DEPAK!
            if not Settings.PriorityIDs[currentID] then
                for _, v in pairs(monsterFolder:GetChildren()) do
                    if isValidTarget(v) then
                        local mID = tostring(v:GetAttribute("ID") or (v:FindFirstChild("ID") and v.ID.Value))
                        if Settings.PriorityIDs[mID] then
                            currentTarget = nil 
                            break
                        end
                    end
                end
            end
        end
    end

    -- Jika target mati, hancur, atau tidak valid, hapus instan dari lock-on
    if currentTarget and not isValidTarget(currentTarget) then
        currentTarget = nil
    end

    --------------------------------------------------
    -- 1. SCAN TARGET BARU (DENGAN HIERARKI KETAT)
    --------------------------------------------------
    if not currentTarget then
        local validPriorities = {}
        local validNormals = {}

        for _, v in pairs(monsterFolder:GetChildren()) do
            if isValidTarget(v) then
                local mID = tostring(v:GetAttribute("ID") or (v:FindFirstChild("ID") and v.ID.Value))
                local pPart = v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
                local distance = (pPart.Position - hrp.Position).Magnitude

                if Settings.PriorityIDs[mID] then
                    table.insert(validPriorities, {monster = v, dist = distance})
                elseif Settings.ActiveIDs[mID] then
                    table.insert(validNormals, {monster = v, dist = distance})
                end
            end
        end

        -- Ambil prioritas paling utama terlebih dahulu
        if #validPriorities > 0 then
            pcall(function() table.sort(validPriorities, function(a, b) return a.dist < b.dist end) end)
            currentTarget = validPriorities[1].monster
        elseif #validNormals > 0 then
            pcall(function() table.sort(validNormals, function(a, b) return a.dist < b.dist end) end)
            currentTarget = validNormals[1].monster
        end
    end

    --------------------------------------------------
    -- 2. LOGIKA TELEPORT KE ENTITIESPOS / AUTO SERVER HOP
    --------------------------------------------------
    if not currentTarget then
        local targetIDToFind = nil
        
        -- Cari tahu ID mana yang statusnya On/True di UI saat ini (Dahulukan Priority)
        for id, enabled in pairs(Settings.PriorityIDs) do
            if enabled then targetIDToFind = id break end
        end
        if not targetIDToFind then
            for id, enabled in pairs(Settings.ActiveIDs) do
                if enabled then targetIDToFind = id break end
            end
        end

        -- Jika tidak ada satu pun list yang ON di UI, matikan paksa PlatformStand agar player bisa bergerak normal kembali
        if not targetIDToFind then
            hopTimer = 0 -- Reset timer karena user memang tidak memilih monster apapun
            if hum.PlatformStand then hum.PlatformStand = false end
            return
        end

        -- [LOGIKA TAMBAHAN: AUTO SERVER HOP TRIGER]
        if Settings.AutoHop then
            if hopTimer == 0 then
                hopTimer = tick() -- Mulai hitung waktu sejak monster terdeteksi kosong
            elseif tick() - hopTimer >= (tonumber(Settings.HopDelay) or 8) then
                hopTimer = 0 -- Reset tracker sebelum pindah
                print("KIIBOO LOG: Monster tidak ditemukan! Memulai Server Hop...")
                task.spawn(ServerHop)
                task.wait(5) -- Jeda aman penahanan loop script
                return
            end
        else
            hopTimer = 0 -- Reset timer jika fitur Auto Hop dimatikan user
        end

        -- Jalankan teleportasi tunggu spawn ke koordinat EntitiesPos selagi menunggu waktu Hop
        if targetIDToFind then
            local spawnPos = getSpawnPosition(targetIDToFind)
            if spawnPos then
                hum.PlatformStand = true
                hrp.Velocity = Vector3.zero
                local currentHeight = tonumber(Settings.Height) or 25
                hrp.CFrame = CFrame.new(spawnPos + Vector3.new(0, currentHeight, 0))
            end
        end
        return 
    else
        -- Jika monster kembali ditemukan sebelum waktu tunda habis, reset timer ke 0 kembali
        hopTimer = 0
    end


    --------------------------------------------------
    -- 3. EKSEKUSI TELEPORT & ATTACK SAMBIL MENGORBIT
    --------------------------------------------------
    if currentTarget and isValidTarget(currentTarget) then
        local tPart = currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget.PrimaryPart
        if tPart then
            hum.PlatformStand = true
            hrp.Velocity = Vector3.zero
            hrp.RotVelocity = Vector3.zero
            
            local orbitSpeed = tonumber(Settings.OrbitSpeed) or 4 
            local angle = tick() * orbitSpeed
            
            local radius = tonumber(Settings.Radius) or 35
            local height = tonumber(Settings.Height) or 25
            
            local offsetX = math.cos(angle) * radius
            local offsetZ = math.sin(angle) * radius
            local targetPos = tPart.Position + Vector3.new(offsetX, height, offsetZ)

            hrp.CFrame = CFrame.new(targetPos, tPart.Position)

            -- Sistem Auto Skill Cast
            if tick() - lastAttack > (tonumber(Settings.AttackDelay) or 0) then
                lastAttack = tick()
                local wID = getWeapon()
                if wID then 
                    pcall(function() RemoteFunc:InvokeServer("\229\136\135\230\141\162\230\137\139\230\140\129\231\137\169\229\147\129", tostring(wID)) end) 
                end
                
                                --------------------------------------------------
                -- MODIFIKASI: MULTI ATTACK 4 JADI PRIORITAS UTAMA
                --------------------------------------------------
                                   --------------------------------------------------
                   -- MODIFIKASI: TIMING TERPISAH (SKILL 4 SPAM, SKILL 1&2 TIAP 3 DETIK)
                   --------------------------------------------------
                   local attackList = {}
                   
                   -- 1. PRIORITAS UTAMA: JIKA MULTI ATTACK 4 ON, LANGSUNG MASUKKAN (TANPA JEDA)
                   if Settings.MultiAttack4 then
                       for i = 1, 8 do
                           table.insert(attackList, 4)
                       end
                   end
                   
                   -- 2. KONDISI KHUSUS: JIKA AUTO ATTACK ON, CEK APAKAH SUDAH BERLALU 3 DETIK?
                   if Settings.AutoAttack then
                       if tick() - lastSkill12Attack >= 3 then
                           lastSkill12Attack = tick() -- Reset timer internal ke 0 kembali
                           table.insert(attackList, 1)
                           table.insert(attackList, 2)
                       end
                   end
                   
                   -- Antisipasi jika Multi Attack OFF dan Skill 1&2 belum waktunya keluar
                   -- Kita masukkan hit dasar (Skill 1) agar script tidak dikira macet/berhenti
                   if #attackList == 0 and not Settings.MultiAttack4 then
                       table.insert(attackList, 1)
                   end
                   --------------------------------------------------


                
                for _, s in pairs(attackList) do
                    task.spawn(function()
                        SkillEvent:FireServer(s, {
                            targetCF = tPart.CFrame, 
                            moveDirectionStr = "Forward", 
                            clientPredictCastId = HttpService:GenerateGUID(false), 
                            characterType = "Player", 
                            releaseCF = hrp.CFrame, 
                            characterId = 0, 
                            trackTargetId = currentTarget.Name
                        })
                    end)
                end
            end
        end
    else
        if hum.PlatformStand then
            hum.PlatformStand = false
        end
    end
end)


