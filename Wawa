local function scanBagForItems()
    local itemIDs = {}
    
    -- STEP 1: Simulasi Buka Tas secara "Silent" (Mirip Silent Sell)
    -- Ini penting agar server mengirimkan data item terbaru ke folder _BagFrame
    pcall(function()
        -- Memanggil Remote untuk membuka antarmuka "Bag"
        talkFunc:InvokeServer("\230\137\147\229\188\128\231\149\140\233\157\162", {"Bag"})
        
        -- Langsung sembunyikan UI Tas agar tidak mengganggu pandangan player
        local screenGui = player.PlayerGui:FindFirstChild("ScreenGui")
        local bagUI = screenGui and screenGui:FindFirstChild("Bag")
        if bagUI then 
            bagUI.Visible = false 
        end
    end)

    -- Jeda singkat agar server sempat sinkronisasi data ke client
    task.wait(0.3)

    -- STEP 2: Scan folder _BagFrame untuk mengambil semua ID Item
    local successScan, BagFrame = pcall(function()
        return player.PlayerGui:WaitForChild("ScreenGui", 5)
            :WaitForChild("Bag", 5)
            :WaitForChild("ContentClip", 5)
            :WaitForChild("Main", 5)
            :WaitForChild("_BagFrame", 5)
    end)
        
    if successScan and BagFrame then
        for _, slot in ipairs(BagFrame:GetChildren()) do
            -- Mencari objek yang memiliki nama format BagSlot_IDItem
            if slot:IsA("GuiObject") and string.match(slot.Name, "^BagSlot_(%d+)") then
                local idStr = string.match(slot.Name, "^BagSlot_(%d+)")
                local itemId = tonumber(idStr)
                if itemId then
                    table.insert(itemIDs, itemId)
                end
            end
        end
    end
    return itemIDs
end

