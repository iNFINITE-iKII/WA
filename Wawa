-- Modular Components
local function makeToggle(txt, key, p, mode)
    local btn = Instance.new("TextButton", p); btn.Size = UDim2.new(1,-10,0,32); btn.BackgroundColor3 = Color3.fromRGB(25,25,25); btn.Text = "  "..txt; btn.TextColor3 = Color3.new(0.8,0.8,0.8); btn.TextXAlignment = "Left"; btn.Font = "Gotham"; btn.TextSize = 11; Instance.new("UICorner", btn)
    local ind = Instance.new("Frame", btn); ind.Size = UDim2.new(0,8,0,8); ind.Position = UDim2.new(1,-20,0.5,-4); ind.BackgroundColor3 = Color3.new(0.6,0,0); Instance.new("UICorner", ind)
    
    btn.MouseButton1Click:Connect(function()
        if mode == "Normal" then Settings.ActiveIDs[key] = not Settings.ActiveIDs[key]
        elseif mode == "Priority" then Settings.PriorityIDs[key] = not Settings.PriorityIDs[key]
        elseif mode == "Quest" then Settings.SelectedQuests[key] = not Settings.SelectedQuests[key]
        elseif mode == "StatToggle" then Settings.AutoStats[key].enabled = not Settings.AutoStats[key].enabled
        else Settings[key] = not Settings[key] end
    end)
    
    RunService.RenderStepped:Connect(function()
        local val = (mode == "Normal" and Settings.ActiveIDs[key]) or (mode == "Priority" and Settings.PriorityIDs[key]) or (mode == "Quest" and Settings.SelectedQuests[key]) or (mode == "StatToggle" and Settings.AutoStats[key].enabled) or Settings[key]
        ind.BackgroundColor3 = val and Color3.new(0,0.8,0.4) or Color3.new(0.6,0,0)
    end)
    return btn
end

local function makeInput(txt, key, p, mode)
    local f = Instance.new("Frame", p); f.Size = UDim2.new(1,-10,0,32); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(0.6,0,1,0); l.Text = " "..txt; l.TextColor3 = Color3.new(0.7,0.7,0.7); l.BackgroundTransparency = 1; l.TextXAlignment = "Left"; l.Font = "Gotham"; l.TextSize = 10
    local b = Instance.new("TextBox", f); b.Size = UDim2.new(0.3,0,0.8,0); b.Position = UDim2.new(0.65,0,0.1,0); b.BackgroundColor3 = Color3.fromRGB(35,35,35); b.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", b)
    
    if mode == "StatAmount" then
        b.Text = tostring(Settings.AutoStats[key].amount)
        b.FocusLost:Connect(function() if tonumber(b.Text) then Settings.AutoStats[key].amount = tonumber(b.Text) end end)
    else
        b.Text = tostring(Settings[key])
        b.FocusLost:Connect(function() if tonumber(b.Text) then Settings[key] = tonumber(b.Text) end end)
    end
end

